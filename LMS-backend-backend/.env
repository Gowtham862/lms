environment:
  SPRING_APPLICATION_NAME: LMS
  SPRING_DATA_MONGODB_URI: mongodb://root:root@mongodb:27017/lmsjson?authSource=admin
  SPRING_SERVLET_MULTIPART_ENABLED: "true"
  SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE: 500MB
  SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE: 500MB
  APP_RESET_PASSWORD_URL: http://localhost:4200/new-password
  TASK_FILE_PATH: uploads/
  SPRING_MAIL_HOST: smtp.gmail.com
  SPRING_MAIL_USERNAME: noreply@yourdomain.com
  SPRING_MAIL_PASSWORD: YOUR_ACTUAL_APP_PASSWORD
  SPRING_MAIL_PORT: 587
  SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH: "true"
  SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE: "true"